import React, { useState, useEffect, useRef } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  signInWithCustomToken, 
  signInAnonymously, 
  onAuthStateChanged,
  signOut
} from 'firebase/auth';
import { 
  getFirestore, 
  doc, 
  setDoc, 
  collection, 
  onSnapshot,
  addDoc, 
  deleteDoc
} from 'firebase/firestore';
import { 
  Trophy, 
  Users, 
  Brain, 
  Send, 
  Activity, 
  Target,
  AlertCircle,
  UserPlus,
  Trash2,
  X,
  ShieldCheck,
  Copy,
  Check,
  Github
} from 'lucide-react';

// Firebase Config
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'bananas-strategy-ai';
const apiKey = ""; // API key is handled by the environment

const App = () => {
  const [user, setUser] = useState(null);
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [activeTab, setActiveTab] = useState('chat');
  const [players, setPlayers] = useState([]);
  const [showAddForm, setShowAddForm] = useState(false);
  const [newPlayer, setNewPlayer] = useState({ name: '', role: '', notes: '' });
  const [copied, setCopied] = useState(false);
  const scrollRef = useRef(null);

  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) {
        console.error("Auth Error:", error);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, (u) => {
      setUser(u);
    });
    return () => unsubscribe();
  }, []);

  useEffect(() => {
    if (!user) return;

    const playersCol = collection(db, 'artifacts', appId, 'users', user.uid, 'players');
    const unsubscribePlayers = onSnapshot(playersCol, (snapshot) => {
      setPlayers(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
    }, (error) => console.error("Players Sync Error:", error));

    const messagesCol = collection(db, 'artifacts', appId, 'users', user.uid, 'messages');
    const unsubscribeMessages = onSnapshot(messagesCol, (snapshot) => {
      const msgs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      const sortedMsgs = msgs.sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp));
      
      if (sortedMsgs.length === 0) {
        setMessages([{ role: 'assistant', content: 'バナナーズ戦略室へようこそ！ここでの会話は君専用のデータとして保存されるよ。' }]);
      } else {
        setMessages(sortedMsgs);
      }
    }, (error) => console.error("Messages Sync Error:", error));

    return () => {
      unsubscribePlayers();
      unsubscribeMessages();
    };
  }, [user]);

  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
  }, [messages]);

  const handleCopyCode = () => {
    const code = document.documentElement.outerHTML;
    const textArea = document.createElement("textarea");
    textArea.value = code;
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    } catch (err) {
      console.error('Copy failed');
    }
    document.body.removeChild(textArea);
  };

  const callGemini = async (userQuery) => {
    const systemPrompt = `
      あなたは野球チーム「バナナーズ」の専属AI戦略コーチです。
      現在のチーム構成: ${JSON.stringify(players.map(p => ({ name: p.name, role: p.role, notes: p.notes })))}
      具体的で情熱的なアドバイスをしてください。
    `;

    let retries = 0;
    while (retries < 5) {
      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: userQuery }] }],
            systemInstruction: { parts: [{ text: systemPrompt }] }
          })
        });
        if (!response.ok) throw new Error('API failed');
        const data = await response.json();
        return data.candidates?.[0]?.content?.parts?.[0]?.text;
      } catch (error) {
        retries++;
        await new Promise(r => setTimeout(r, Math.pow(2, retries) * 1000));
      }
    }
    return "通信エラーが発生しました。";
  };

  const handleSend = async () => {
    if (!input.trim() || loading || !user) return;
    
    const userMessage = { 
      role: 'user', 
      content: input, 
      timestamp: new Date().toISOString() 
    };
    
    const messagesCol = collection(db, 'artifacts', appId, 'users', user.uid, 'messages');
    setInput('');
    setLoading(true);

    try {
      await addDoc(messagesCol, userMessage);
      const aiResponse = await callGemini(userMessage.content);
      await addDoc(messagesCol, { 
        role: 'assistant', 
        content: aiResponse, 
        timestamp: new Date().toISOString() 
      });
    } catch (e) {
      console.error("Chat Error:", e);
    } finally {
      setLoading(false);
    }
  };

  const addPlayer = async () => {
    if (!newPlayer.name.trim() || !user) return;
    try {
      const playersCol = collection(db, 'artifacts', appId, 'users', user.uid, 'players');
      await addDoc(playersCol, { ...newPlayer, createdAt: new Date().toISOString() });
      setNewPlayer({ name: '', role: '', notes: '' });
      setShowAddForm(false);
    } catch (e) {
      console.error("Player Add Error:", e);
    }
  };

  const removePlayer = async (id) => {
    if (!user) return;
    try {
      await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'players', id));
    } catch (e) {
      console.error("Player Delete Error:", e);
    }
  };

  return (
    <div className="flex flex-col h-screen bg-slate-900 text-slate-100 font-sans">
      <header className="p-4 bg-yellow-400 text-slate-900 flex items-center justify-between shadow-lg z-10">
        <div className="flex items-center gap-2">
          <Trophy className="w-8 h-8" />
          <h1 className="text-xl font-black italic tracking-tighter">BANANAS GITHUB</h1>
        </div>
        
        <div className="flex items-center gap-3">
          <button 
            onClick={handleCopyCode}
            className="flex items-center gap-2 bg-slate-900 text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-slate-800 transition"
          >
            {copied ? <Check className="w-4 h-4 text-green-400" /> : <Copy className="w-4 h-4" />}
            {copied ? 'COPIED!' : 'COPY'}
          </button>
          <div className="flex gap-1 bg-slate-900/10 p-1 rounded-full text-xs">
            <button 
              onClick={() => setActiveTab('chat')}
              className={`px-4 py-1.5 rounded-full font-bold transition ${activeTab === 'chat' ? 'bg-slate-900 text-yellow-400' : 'text-slate-800'}`}
            >
              戦略
            </button>
            <button 
              onClick={() => setActiveTab('roster')}
              className={`px-4 py-1.5 rounded-full font-bold transition ${activeTab === 'roster' ? 'bg-slate-900 text-yellow-400' : 'text-slate-800'}`}
            >
              名簿
            </button>
          </div>
        </div>
      </header>

      <main className="flex-1 overflow-hidden flex flex-col relative">
        {activeTab === 'chat' ? (
          <>
            <div ref={scrollRef} className="flex-1 overflow-y-auto p-4 space-y-4">
              {messages.map((msg, i) => (
                <div key={msg.id || i} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                  <div className={`max-w-[85%] p-4 rounded-2xl shadow-sm ${
                    msg.role === 'user' 
                      ? 'bg-yellow-400 text-slate-900 rounded-tr-none' 
                      : 'bg-slate-800 text-slate-100 rounded-tl-none border border-slate-700'
                  }`}>
                    <p className="whitespace-pre-wrap leading-relaxed">{msg.content}</p>
                  </div>
                </div>
              ))}
              {loading && (
                <div className="flex justify-start animate-pulse text-sm p-4 text-slate-500">
                  <Brain className="w-4 h-4 animate-bounce text-yellow-400 inline mr-2" /> 思考中...
                </div>
              )}
            </div>
            <div className="p-4 bg-slate-800 border-t border-slate-700">
              <div className="max-w-4xl mx-auto relative">
                <input 
                  type="text"
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  onKeyPress={(e) => e.key === 'Enter' && handleSend()}
                  placeholder="メッセージを入力..."
                  className="w-full bg-slate-900 border border-slate-600 rounded-full py-3 px-5 pr-14 focus:outline-none focus:border-yellow-400"
                />
                <button 
                  onClick={handleSend}
                  disabled={loading || !input.trim()}
                  className="absolute right-1.5 top-1.5 bottom-1.5 bg-yellow-400 text-slate-900 px-4 rounded-full font-bold hover:bg-yellow-300 disabled:opacity-50 transition"
                >
                  <Send className="w-4 h-4" />
                </button>
              </div>
            </div>
          </>
        ) : (
          <div className="flex-1 overflow-y-auto p-6 space-y-6">
            <div className="flex justify-between items-center">
              <h2 className="text-xl font-bold flex items-center gap-2 text-yellow-400 italic"><Users className="w-6 h-6" /> ROSTER ({players.length})</h2>
              <button 
                onClick={() => setShowAddForm(true)}
                className="bg-yellow-400 text-slate-900 px-4 py-2 rounded-lg font-bold flex items-center gap-2 hover:bg-yellow-300 transition"
              >
                <UserPlus className="w-4 h-4" /> 追加
              </button>
            </div>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {players.map((p) => (
                <div key={p.id} className="bg-slate-800 p-5 rounded-2xl border border-slate-700 relative group overflow-hidden">
                  <div className="absolute top-0 left-0 w-1.5 h-full bg-yellow-400"></div>
                  <button onClick={() => removePlayer(p.id)} className="absolute top-3 right-3 p-2 text-slate-500 hover:text-red-400 transition"><Trash2 className="w-4 h-4" /></button>
                  <h3 className="font-bold text-lg text-white mb-1">{p.name}</h3>
                  <div className="mb-2"><span className="text-[10px] bg-yellow-400/10 text-yellow-400 px-2 py-0.5 rounded font-black border border-yellow-400/20">{p.role || '未設定'}</span></div>
                  <p className="text-sm text-slate-400">“{p.notes || '-'}”</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {showAddForm && (
          <div className="absolute inset-0 bg-slate-950/90 backdrop-blur-md flex items-center justify-center p-4 z-50">
            <div className="bg-slate-800 border-2 border-yellow-400/20 rounded-3xl w-full max-w-md shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
              <div className="p-5 bg-yellow-400 text-slate-900 flex justify-between items-center">
                <h3 className="font-black italic uppercase">New Player</h3>
                <button onClick={() => setShowAddForm(false)}><X className="w-6 h-6" /></button>
              </div>
              <div className="p-6 space-y-4">
                <input type="text" value={newPlayer.name} onChange={(e) => setNewPlayer({...newPlayer, name: e.target.value})} className="w-full bg-slate-900 border border-slate-700 rounded-xl p-4 outline-none" placeholder="名前"/>
                <input type="text" value={newPlayer.role} onChange={(e) => setNewPlayer({...newPlayer, role: e.target.value})} className="w-full bg-slate-900 border border-slate-700 rounded-xl p-4 outline-none" placeholder="ポジション"/>
                <textarea value={newPlayer.notes} onChange={(e) => setNewPlayer({...newPlayer, notes: e.target.value})} className="w-full bg-slate-900 border border-slate-700 rounded-xl p-4 outline-none h-24" placeholder="特徴・メモ"/>
                <button onClick={addPlayer} disabled={!newPlayer.name} className="w-full bg-yellow-400 text-slate-900 py-4 rounded-xl font-bold hover:bg-yellow-300 transition">登録する</button>
              </div>
            </div>
          </div>
        )}
      </main>

      <footer className="bg-slate-950 p-2 flex justify-between px-6 text-[9px] text-slate-500 font-bold border-t border-slate-800 uppercase tracking-widest">
        <div className="flex items-center gap-4">
          <span className="flex items-center gap-1"><Activity className="w-3 h-3 text-green-400" /> CLOUD: SYNCED</span>
          <span className="flex items-center gap-1 text-yellow-400"><Github className="w-3 h-3" /> READY FOR GITHUB</span>
        </div>
        <div>BANANAS AI v2.2</div>
      </footer>
    </div>
  );
};

export default App;